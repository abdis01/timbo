rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User data: only the authenticated user can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // User subcollections: same rule applies
      match /notes/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /expenses/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /reminders/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /captures/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Waitlist: anyone can create (sign up), only admins can read
    match /waitlist/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.email == 'admin@timbo.app';
      allow list: if false;
    }
  }
}
